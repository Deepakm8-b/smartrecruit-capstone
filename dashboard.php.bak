<?php
session_start();
require_once 'db.php';
require_once 'profile_strength.php';

if (!isset($_SESSION['user_id']) || $_SESSION['role'] !== 'student') {
    header('Location: login.php');
    exit;
}

$studentId = $_SESSION['user_id'];

$stmt = $pdo->prepare('SELECT s.full_name, s.degree, s.university, u.email FROM students s JOIN users u ON s.user_id = u.user_id WHERE u.user_id = ?');
$stmt->execute([$studentId]);
$student = $stmt->fetch();

$stmt = $pdo->prepare('SELECT s.student_id FROM students s WHERE s.user_id = ?');
$stmt->execute([$studentId]);
$stdData = $stmt->fetch();
$studentRecordId = $stdData['student_id'] ?? 0;

$isPremium = true;

$stmt = $pdo->prepare('SELECT COUNT(*) FROM jobs');
$stmt->execute();
$matchCount = $stmt->fetchColumn();

$stmt = $pdo->prepare('SELECT COUNT(*) FROM applications WHERE student_id = ?');
$stmt->execute([$studentRecordId]);
$appCount = $stmt->fetchColumn();

$stmt = $pdo->prepare('SELECT COUNT(*) FROM applications WHERE student_id = ? AND status = "Shortlisted"');
$stmt->execute([$studentRecordId]);
$shortlistedCount = $stmt->fetchColumn();

$profileScore = calculateProfileStrength($pdo, $studentRecordId);

$stmt = $pdo->prepare('SELECT j.job_id, j.job_title, j.company, j.location, j.job_type, j.salary_range, j.required_skills, j.created_date FROM jobs j ORDER BY j.created_date DESC LIMIT 5');
$stmt->execute();
$topJobs = $stmt->fetchAll();
?>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard - SmartRecruit</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
