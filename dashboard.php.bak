            <?php if ($isPremium): ?>
                <span class="premium-badge">⭐ Premium</span>
            <?php endif; ?>
        </div>

        <div class="sidebar-nav">
            <a href="dashboard.php" class="active">📊 Dashboard</a>
            <a href="jobs.php">💼 Job Matches</a>
            <a href="applications.php">📋 Applications</a>
            <a href="roadmap.php">🗺️ Roadmap</a>
            <a href="profile.php">👤 Profile</a>
            <?php if ($isPremium): ?>
                <a href="training.php">⭐ Training</a>
                <a href="referrals.php">⭐ Referrals</a>
                <a href="reference.php">⭐ Reference</a>
            <?php else: ?>
                <a href="upgrade.php">⭐ Upgrade</a>
            <?php endif; ?>
        </div>

        <div class="progress-section">
            <div class="progress-label">Profile Strength</div>
            <div class="progress-bar">
                <div class="progress-fill" style="width:<?php echo $profileScore; ?>%"></div>
            </div>
            <div class="progress-pct"><?php echo $profileScore; ?>%</div>
        </div>
    </div>

    <div class="main">
        <div class="page-title">Welcome back, <?php echo htmlspecialchars($student['full_name']); ?> 👋</div>

        <?php if (!$isPremium): ?>
            <div class="premium-banner">
                <div>
                    <h3>⭐ Unlock Premium</h3>
                    <p>Access training, referrals, and reference letters</p>
                </div>
                <a href="upgrade.php" class="upgrade-btn">Upgrade Now</a>
            </div>
        <?php endif; ?>

        <div class="stats">
            <div class="stat-card">
                <div class="stat-num"><?php echo $matchCount; ?></div>
                <div class="stat-label">Job Matches</div>
            </div>
            <div class="stat-card">
                <div class="stat-num"><?php echo $appCount; ?></div>
                <div class="stat-label">Applied</div>
            </div>
            <div class="stat-card">
                <div class="stat-num"><?php echo $shortlistedCount; ?></div>
                <div class="stat-label">Shortlisted</div>
            </div>
        </div>

        <div class="section-title">Top Recommended Jobs</div>
        <div class="jobs">
            <?php if (count($topJobs) > 0): ?>
                <?php foreach ($topJobs as $job): ?>
                    <div class="jcard">
                        <div>
                            <div class="jtitle"><?php echo htmlspecialchars($job['job_title']); ?></div>
                            <div class="jcomp"><?php echo htmlspecialchars($job['company']); ?> · <?php echo htmlspecialchars($job['location']); ?></div>
                            <div class="tags">
                                <?php if ($job['required_skills']): ?>
                                    <?php foreach (explode(',', $job['required_skills']) as $skill): ?>
                                        <span class="tag"><?php echo trim($skill); ?></span>
                                    <?php endforeach; ?>
                                <?php endif; ?>
                            </div>
                        </div>
                        <div>
                            <span class="match">92%</span>
                        </div>
                    </div>
                <?php endforeach; ?>
            <?php else: ?>
                <p style="color: #6b7280;">No jobs available</p>
            <?php endif; ?>
        </div>
    </div>
</div>

