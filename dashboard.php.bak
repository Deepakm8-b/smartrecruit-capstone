.sidebar-nav a { padding: 10px 12px; border-radius: 6px; text-decoration: none; color: #6b7280; font-size: 13px; font-weight: 600; }
.sidebar-nav a:hover { background: #f3f4f6; color: #1e40af; }
.sidebar-nav a.active { background: #dbeafe; color: #1e40af; }
