<?php
session_start();
require_once 'db.php';
require_once 'functions.php';

if (!isset($_SESSION['user_id'])) { header('Location: login.php'); exit; }

$userId = $_SESSION['user_id'];
$student = getStudentByUserId($pdo, $userId);
$jobId = intval($_GET['id'] ?? 0);

// Get job details
$stmt = $pdo->prepare('SELECT * FROM jobs WHERE job_id = ?');
$stmt->execute([$jobId]);
$job = $stmt->fetch();

if (!$job) { header('Location: dashboard.php'); exit; }

// Check if already applied
$stmt = $pdo->prepare('SELECT * FROM applications WHERE student_id = ? AND job_id = ?');
$stmt->execute([$student['student_id'], $jobId]);
$alreadyApplied = $stmt->fetch() ? true : false;
?>
